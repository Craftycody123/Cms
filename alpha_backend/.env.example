# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Security
SECRET_KEY=your-super-secure-key-change-in-production-min-32-chars-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ENVIRONMENT=development

# Admin
ADMIN_EMAIL=admin@alpha.com
ADMIN_PASSWORD=your-secure-password

# Email (optional - currently unused)
MAIL_FROM=hello@alpha.com
MAIL_SERVER=smtp.example.com
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-password

# Frontend
FRONTEND_ORIGIN=http://localhost:3000,http://localhost:3001

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
